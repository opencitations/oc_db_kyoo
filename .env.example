# ── General ─────────────────────────────────────────────────────
LISTEN_PORT=8080
LOG_LEVEL=info

# ── Queue settings ──────────────────────────────────────────────
MAX_CONCURRENT_PER_BACKEND=10
MAX_QUEUE_PER_BACKEND=250
QUEUE_TIMEOUT=180
BACKEND_TIMEOUT=60

# ── Circuit breaker ────────────────────────────────────────────
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_TIME=15

# ── Health check probe ─────────────────────────────────────────
HEALTH_CHECK_INTERVAL=10
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_QUERY=ASK WHERE { ?s ?p ?o }

# ── Primary backends (BACKEND_N_*) ─────────────────────────────
# Backend 0
BACKEND_0_NAME=virtuoso-1
BACKEND_0_HOST=meta-db-virtuoso-1-0.virtuoso-service.default.svc.cluster.local
BACKEND_0_PORT=8890
BACKEND_0_PATH=/sparql
# Backend 1
BACKEND_1_NAME=virtuoso-2
BACKEND_1_HOST=meta-db-virtuoso-2-0.virtuoso-service.default.svc.cluster.local
BACKEND_1_PORT=8890
BACKEND_1_PATH=/sparql
# Backend 2
BACKEND_2_NAME=virtuoso-3
BACKEND_2_HOST=meta-db-virtuoso-3-0.virtuoso-service.default.svc.cluster.local
BACKEND_2_PORT=8890
BACKEND_2_PATH=/sparql

# ── Fallback backends (FALLBACK_N_*) ───────────────────────────
# Activated only when ALL primary backends have circuit OPEN
FALLBACK_MAX_CONCURRENT_PER_BACKEND=3
FALLBACK_MAX_QUEUE_PER_BACKEND=20
FALLBACK_QUEUE_TIMEOUT=120
FALLBACK_BACKEND_TIMEOUT=120
# Fallback 0
# FALLBACK_0_NAME=virtuoso-fb-1
# FALLBACK_0_HOST=virtuoso-fb-1.default.svc.cluster.local
# FALLBACK_0_PORT=8890
# FALLBACK_0_PATH=/sparql
