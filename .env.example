# oc_db_kyoo Docker image version
DB_KYOO_VERSION=1.0.0

# ── Virtuoso Queue Manager ──────────────────────────────────────
KYOO_VIRTUOSO_MAX_CONCURRENT=10
KYOO_VIRTUOSO_MAX_QUEUE=50
KYOO_VIRTUOSO_QUEUE_TIMEOUT=120
KYOO_VIRTUOSO_BACKEND_TIMEOUT=900
# Backend 0
KYOO_VIRTUOSO_0_HOST=meta-db-virtuoso-1-0.virtuoso-service.default.svc.cluster.local
KYOO_VIRTUOSO_0_PORT=8890
KYOO_VIRTUOSO_0_PATH=/sparql
# Backend 1
KYOO_VIRTUOSO_1_HOST=meta-db-virtuoso-2-0.virtuoso-service.default.svc.cluster.local
KYOO_VIRTUOSO_1_PORT=8890
KYOO_VIRTUOSO_1_PATH=/sparql
# Backend 2
KYOO_VIRTUOSO_2_HOST=meta-db-virtuoso-3-0.virtuoso-service.default.svc.cluster.local
KYOO_VIRTUOSO_2_PORT=8890
KYOO_VIRTUOSO_2_PATH=/sparql

# ── QLever Queue Manager ────────────────────────────────────────
KYOO_QLEVER_MAX_CONCURRENT=15
KYOO_QLEVER_MAX_QUEUE=80
KYOO_QLEVER_QUEUE_TIMEOUT=120
KYOO_QLEVER_BACKEND_TIMEOUT=900
# Backend 0
KYOO_QLEVER_0_HOST=qlever-1.default.svc.cluster.local
KYOO_QLEVER_0_PORT=7011
KYOO_QLEVER_0_PATH=/
